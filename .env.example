# HDU Library Sniper - Docker 环境变量示例
# 复制此文件为 .env 并填入你的信息

# 容器/服务器运行根目录；桌面端无需设置
HDU_SNIPER_HOME=/var/lib/hdu-sniper

# 杭电统一身份认证凭据
HDU_STUDENT_ID=你的学号
HDU_PASSWORD=你的密码

# 生产环境建议改用 secret 文件，并删除上面两个明文变量
# HDU_STUDENT_ID_FILE=/run/secrets/student_id
# HDU_PASSWORD_FILE=/run/secrets/password

# Web UI 对外端口
HDU_WEB_PORT=8000

# 微信 Webhook 通知（可选）
HDU_WECHAT_WEBHOOK=
