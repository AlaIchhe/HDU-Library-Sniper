# HDU Library Sniper - Docker 环境变量示例
# 复制此文件为 .env 并填入你的信息

# 杭电统一身份认证凭据
HDU_STUDENT_ID=你的学号
HDU_PASSWORD=你的密码

# 定时任务配置（cron 格式）
# 示例：
#   0 20 * * *    每天 20:00
#   55 19 * * *   每天 19:55
#   */30 * * * *  每 30 分钟
SCHEDULE=0 20 * * *

# X11 显示配置（Linux/macOS GUI 模式）
DISPLAY=:0

# 微信 Webhook 通知（可选）
WECHAT_WEBHOOK=
